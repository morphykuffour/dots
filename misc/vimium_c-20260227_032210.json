		"# Advanced hint system with auto-activation",
		"map gE openUrl url=\"javascript:(function(){const\\u0020editables=document.querySelectorAll('input[type=text],input[type=search],input[type=email],input[type=password],textarea,[contenteditable=true]');if(editables.length===0){alert('No\\u0020editable\\u0020fields\\u0020found');return;}const\\u0020hints=[];const\\u0020hintChars='asdfghjklqwertyuiopzxcvbnm';const\\u0020validEditables=[];editables.forEach((el,idx)=>{const\\u0020rect=el.getBoundingClientRect();if(rect.width>0&&rect.height>0&&rect.top>=0&&rect.left>=0&&rect.bottom<=window.innerHeight&&rect.right<=window.innerWidth){validEditables.push(el);}});validEditables.forEach((el,idx)=>{const\\u0020rect=el.getBoundingClientRect();const\\u0020hint=document.createElement('div');hint.className='vimium-chrome-emacs-hint';hint.style.cssText='position:fixed;z-index:2147483647;background:#ffeb3b;color:black;padding:2px\\u00206px;border:2px\\u0020solid\\u0020black;font-family:monospace;font-size:14px;font-weight:bold;top:'+(rect.top-2)+'px;left:'+(rect.left-2)+'px;pointer-events:none;box-shadow:0\\u00202px\\u00204px\\u0020rgba(0,0,0,0.3);';hint.textContent=hintChars[idx%hintChars.length].toUpperCase();document.body.appendChild(hint);hints.push({hint,element:el,char:hintChars[idx%hintChars.length]});});if(hints.length===0){alert('No\\u0020visible\\u0020text\\u0020fields\\u0020found');return;}function\\u0020cleanup(){hints.forEach(h=>h.hint.remove());document.removeEventListener('keypress',handleKeyPress);document.removeEventListener('keydown',handleEscape);}function\\u0020activateChromeEmacs(element){element.focus();element.click();setTimeout(()=>{element.click();},100);}function\\u0020handleKeyPress(e){const\\u0020match=hints.find(h=>h.char===e.key.toLowerCase());if(match){cleanup();activateChromeEmacs(match.element);}}function\\u0020handleEscape(e){if(e.key==='Escape'){cleanup();}}document.addEventListener('keypress',handleKeyPress);document.addEventListener('keydown',handleEscape);})();\"",
