#!/usr/bin/env zsh

# -------------------------------- FUNCTIONS ---------------------------------

# -------------------------------- TMUX ALIAS EXPANSION ---------------------------------
# Expands aliases in tmux window title so you see "git commit" instead of "gca"

# Function to expand a single alias to its definition
_expand_alias() {
    local cmd="$1"
    local expanded

    # Check if the command is an alias
    if expanded=$(alias "$cmd" 2>/dev/null); then
        # Extract just the expansion part (after the '=')
        expanded="${expanded#*=}"
        # Remove surrounding quotes if present
        expanded="${expanded#[\'\"]}"
        expanded="${expanded%[\'\"]}"
        echo "$expanded"
        return 0
    fi
    return 1
}

# Function to intelligently expand command for display
_expand_command_for_display() {
    local full_cmd="$1"
    local first_word="${full_cmd%% *}"
    local rest=""

    # Get everything after the first word
    if [[ "$full_cmd" == *" "* ]]; then
        rest=" ${full_cmd#* }"
    fi

    # Try to expand the first word if it's an alias
    local expanded
    if expanded=$(_expand_alias "$first_word"); then
        # For compound aliases like "git add .; git commit", just show the main action
        if [[ "$expanded" == *";"* ]] || [[ "$expanded" == *"&&"* ]]; then
            local primary_cmd="${expanded%%;*}"
            primary_cmd="${primary_cmd%%&&*}"
            primary_cmd="${primary_cmd## }"
            primary_cmd="${primary_cmd%% }"
            echo "${primary_cmd}${rest}"
        else
            echo "${expanded}${rest}"
        fi
    else
        echo "$full_cmd"
    fi
}

# Preexec hook - runs before each command
_tmux_expand_alias_preexec() {
    [[ -z "$TMUX" ]] && return
    local cmd="$1"
    [[ -z "${cmd// }" ]] && return

    local expanded=$(_expand_command_for_display "$cmd")
    if [[ ${#expanded} -gt 30 ]]; then
        expanded="${expanded:0:27}..."
    fi
    tmux rename-window "$expanded" 2>/dev/null
}

# Precmd hook - runs before prompt is displayed
_tmux_expand_alias_precmd() {
    [[ -z "$TMUX" ]] && return
    tmux rename-window "${PWD##*/}" 2>/dev/null
}

# Register hooks
if [[ -n "$ZSH_VERSION" ]]; then
    autoload -Uz add-zsh-hook
    add-zsh-hook preexec _tmux_expand_alias_preexec
    add-zsh-hook precmd _tmux_expand_alias_precmd
fi

# -------------------------------- FILE SOURCING ---------------------------------

zsh_add_file() {
    [ -f "$ZDOTDIR/$1" ] && source "$ZDOTDIR/$1"
}

zsh_add_plugin() {
    PLUGIN_NAME=$(basename "$1" | cut -f 1 -d '.')
    if [ -d "$ZDOTDIR/plugins/$PLUGIN_NAME" ]; then
        zsh_add_file "plugins/$PLUGIN_NAME/$PLUGIN_NAME.plugin.zsh" || \
        zsh_add_file "plugins/$PLUGIN_NAME/$PLUGIN_NAME.zsh"
    else
        git clone "$1" "$ZDOTDIR/plugins/$PLUGIN_NAME"
    fi
}

# -------------------------------- FZF FUNCTIONS ---------------------------------

# Edit dotfiles with fzf
function vif() {
    local fname
    local current_dir=$PWD
    cd ~/dots || exit
    fname=$(fzf --preview 'bat {} ') || return
    nvim "$fname"
    cd "$current_dir"
}
bindkey -s '^p' 'vif^M'

# Edit nix files with fzf
function nif() {
    local fname
    local current_dir=$PWD
    cd ~/nix || exit
    fname=$(fzf --preview 'bat {} ') || return
    nvim "$fname"
    cd "$current_dir"
}
bindkey -s '^n' 'nif^M'

# Find and open files
function vao() {
    fname=$(fd --type f --hidden --follow --exclude .git | fzf --preview 'bat --color=always {}') || return
    nvim "$fname"
}
bindkey -s '^f' 'vao^M'

# Search and open files
function search() {
    fname=$(fzf --preview 'bat {}' --multi --bind 'enter:select-all+accept') || return
    nvim "$fname"
}

# fzf with command
function fz() {
    local sels=( "${(@f)$(fd --color=always . "${@:2}" | fzf -m --height=25% --reverse --ansi)}" )
    [ -n "$sels" ] && print -z -- "$1 ${sels[@]:q:q}"
}

# vim to go line (ripgrep to quickfix)
function vgol() {
    rg --vimgrep "$1" | nvim -q /dev/stdin
}

# Enhanced rm with fzf
function fzf-rm() {
    if [[ "$#" -eq 0 ]]; then
        local files
        files=$(find . -maxdepth 1 -type f | fzf --multi)
        echo "$files" | xargs -I '{}' rm {}
    else
        command rm "$@"
    fi
}

# Search list of aliases and functions
fzf-aliases-functions() {
    CMD=$(
        (
            (alias)
            (functions | grep "()" | cut -d ' ' -f1 | grep -v "^_" )
        ) | fzf | cut -d '=' -f1
    )
    eval "$CMD"
}

# File Finder (Open in $EDITOR)
fzf-find-files() {
    local file=$(fzf --multi --reverse)
    if [[ $file ]]; then
        for prog in $(echo $file); do
            $EDITOR "$prog"
        done
    else
        echo "cancelled fzf"
    fi
}

# Find directories
fzf-cd() {
    local dir
    dir=$(find ${1:-.} -path '*/\.*' -prune -o -type d -print 2> /dev/null | fzf +m) &&
    cd "$dir"
    ls
}

# Find directories including hidden
function fzf-cd-incl-hidden() {
    local dir
    dir=$(find ${1:-.} -type d 2> /dev/null | fzf +m) && cd "$dir"
    ls
}

# cd into directory of selected file
function fzf-cd-to-file() {
    local file dir
    file=$(fzf +m -q "$1") && dir=$(dirname "$file") && cd "$dir"
    ls
}

# cd to selected parent directory
function fzf-cd-to-parent() {
    local declare dirs=()
    get_parent_dirs() {
        if [[ -d "${1}" ]]; then dirs+=("$1"); else return; fi
        if [[ "${1}" == '/' ]]; then
            for _dir in "${dirs[@]}"; do echo "$_dir"; done
        else
            get_parent_dirs $(dirname "$1")
        fi
    }
    local DIR=$(get_parent_dirs $(realpath "${1:-$PWD}") | fzf-tmux --tac)
    cd "$DIR"
    ls
}

# Search env variables
function fzf-env-vars() {
    local out
    out=$(env | fzf)
    echo $(echo "$out" | cut -d= -f2)
}

# Kill process with fzf
function fzf-kill-processes() {
    local pid
    pid=$(ps -ef | sed 1d | fzf -m | awk '{print $2}')
    if [ "x$pid" != "x" ]; then
        echo "$pid" | xargs kill -${1:-9}
    fi
}

# -------------------------------- UTILITIES ---------------------------------

# Extract archives
extract() {
    if [ -f "$1" ]; then
        case $1 in
            *.tar.bz2)   tar xjf "$1"     ;;
            *.tar.gz)    tar xzf "$1"     ;;
            *.tar.xz)    tar xf  "$1"     ;;
            *.bz2)       bunzip2 "$1"     ;;
            *.rar)       unar    "$1"     ;;
            *.gz)        gunzip  "$1"     ;;
            *.tar)       tar xf  "$1"     ;;
            *.tbz2)      tar xjf "$1"     ;;
            *.tgz)       tar xzf "$1"     ;;
            *.zip)       unzip   "$1"     ;;
            *.Z)         uncompress "$1"  ;;
            *.7z)        7z x    "$1"     ;;
            *.zst)       unzstd  "$1"     ;;
            *.xz)        unxz    "$1"     ;;
            *)           echo "'$1' cannot be extracted via extract()" ;;
        esac
    else
        echo "'$1' is not a valid file"
    fi
}

# Add to PATH (avoid duplicates)
addToPath() {
    if [[ "$PATH" != *"$1"* ]]; then
        export PATH=$PATH:$1
    fi
}

addToPathFront() {
    if [[ "$PATH" != *"$1"* ]]; then
        export PATH=$1:$PATH
    fi
}

# Create new script with shebang
shebang() {
    if i=$(which "$1"); then
        printf '#!/usr/bin/env %s\n\n' "$1" > "$2" && chmod 755 "$2" && vim + "$2" && chmod 755 "$2"
    else
        echo "'which' could not find $1, is it in your \$PATH?"
    fi
    rehash
}

# Commit dotfiles
commitDotFiles() {
    cd "$HOME"/dots || exit
    git add .
    git commit
}

# Make directory and cd into it
mkd() {
    if [ -z "$1" ]; then
        echo "Enter a directory name"
    elif [ -d "$1" ]; then
        echo "\`$1' already exists"
    else
        mkdir "$1" && cd "$1" || exit
    fi
}

# Change wallpaper with fzf (Linux)
change_background() {
    feh --randomize --bg-scale --no-xinerama "$HOME/Pictures/wallpapers/$(ls "$HOME/Pictures/wallpapers" | fzf --preview 'sxiv {}')"
}

# Conda shell for NixOS
function conda-shell {
    nix-shell ~/.conda-shell.nix
}

# Set brightness of external display (macOS with m1ddc)
function b() {
    if [ -z "$1" ] || [ "$1" = "--help" ]; then
        printf "%s\n" "Usage: b integer"
        return 0
    fi
    m1ddc set luminance "$1" > /dev/null
}

# Cross-platform open command
function o() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: o <file|directory|URL>"
        return 1
    fi

    case "$OSTYPE" in
        darwin*)
            open "$@"
            ;;
        linux*)
            if command -v xdg-open &> /dev/null; then
                xdg-open "$@" &> /dev/null
            elif command -v wslview &> /dev/null; then
                wslview "$@"
            elif [[ -f /proc/sys/fs/binfmt_misc/WSLInterop ]]; then
                explorer.exe "$@"
            else
                echo "Error: No suitable 'open' command found for Linux"
                return 1
            fi
            ;;
        msys*|cygwin*|win32)
            start "$@"
            ;;
        *)
            echo "Error: Unsupported operating system: $OSTYPE"
            return 1
            ;;
    esac
}

# Open last downloaded file
function ord() {
    downloads_dir="$HOME/Downloads"
    latest_file=$(\ls -t "$downloads_dir" | head -n 1)
    if [[ -n $latest_file ]]; then
        full_path="$downloads_dir/$latest_file"
        echo "Latest downloaded file: $latest_file"
        o "$full_path"
    else
        echo "No files found in the Downloads folder."
    fi
}

# Edit agenix secrets (must be run from ~/nix)
function agenix-edit() {
    local current_dir="$PWD"
    local secret_file="${1:-secrets/openai.age}"
    local identity="${2:-$HOME/.ssh/id_ed25519}"

    cd ~/nix || { echo "Error: ~/nix directory not found"; return 1; }
    agenix -e "$secret_file" -i "$identity"
    cd "$current_dir"
}

# Quick edit OpenAI API key
function edit-openai-key() {
    agenix-edit secrets/openai.age
}

# Download youtube videos
function ytdl() {
    if [[ -z "$1" ]]; then
        echo "Usage: ytdl <URL> [output-name]"
        echo "Downloads video in 1080p (fallback to 720p) with best audio"
        return 1
    fi

    local url="$1"
    local output="${2:-%(title)s.%(ext)s}"

    yt-dlp \
        -f "bestvideo[height<=1080][ext=mp4]+bestaudio[ext=m4a]/bestvideo[height<=1080]+bestaudio/bestvideo[height<=720]+bestaudio/best" \
        --merge-output-format mp4 \
        --embed-thumbnail \
        --embed-metadata \
        -o "$output" \
        "$url"
}

# -------------------------------- FILE MANAGER (lf) ---------------------------------

# lf with directory change
lfcd() {
    tmp="$(mktemp)"
    lf -last-dir-path="$tmp" "$@"
    if [ -f "$tmp" ]; then
        dir="$(cat "$tmp")"
        rm -f "$tmp"
        [ -d "$dir" ] && [ "$dir" != "$(pwd)" ] && cd "$dir"
    fi
}
bindkey -s '^o' 'lfcd\n'

# -------------------------------- DOCKER ---------------------------------

# neovim in docker
dv() {
    sudo docker run \
        -it -v "$(pwd)":/mnt/volume \
        -v "$HOME/.config/nvim":/home/neovim/.config/nvim \
        --workdir=/mnt/volume \
        anatolelucet/neovim:stable \
        "$@"
}
