#!/usr/bin/env bash
# Tailscale SSH convenience wrapper
# Uses Tailscale MagicDNS names instead of hardcoded IPs

# Load private config if available
[[ -f ~/.zshenv.local ]] && source ~/.zshenv.local

case "$1" in
    "optiplex"|"server")
        exec ssh morph@optiplex "${@:2}"
        ;;
    "xps17"|"laptop")
        exec ssh morph@xps17 "${@:2}"
        ;;
    "raspberry"|"pi")
        exec ssh user@raspberry "${@:2}"
        ;;
    "truenas"|"nas")
        exec ssh root@truenas "${@:2}"
        ;;
    "list"|"ls")
        echo "Available systems (using Tailscale MagicDNS):"
        echo "  optiplex, server   -> morph@optiplex"
        echo "  xps17, laptop      -> morph@xps17"
        echo "  raspberry, pi      -> user@raspberry"
        echo "  truenas, nas       -> root@truenas"
        echo ""
        echo "Note: Requires Tailscale MagicDNS enabled"
        ;;
    *)
        echo "Tailscale SSH Helper"
        echo "Usage: $0 {optiplex|xps17|raspberry|truenas|list} [command]"
        echo ""
        echo "Examples:"
        echo "  $0 optiplex                    # SSH to optiplex"
        echo "  $0 server 'systemctl status'   # Run command on server"
        echo "  $0 list                         # List available systems"
        ;;
esac
