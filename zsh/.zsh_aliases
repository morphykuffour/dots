#!/bin/sh

# -------------------------------- NAVIGATION ---------------------------------
alias dots="cd ~/dots"
alias jorg="cd ~/Org"
alias jnix="cd ~/nix"
# jpmd alias moved to ~/.zshenv.local (contains email in path)

alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
alias -- -="cd -"
alias ~="cd ~"
alias d="dirs -v"

# -------------------------------- FILE LISTING ---------------------------------
alias ls="exa"
alias ll='ls -la'
alias la='ls -a'
alias l='ls -F'

# -------------------------------- COMMON COMMANDS ---------------------------------
# Colorize output
alias grep='grep --color=auto'
alias egrep='egrep --color=auto'
alias fgrep='fgrep --color=auto'
alias ip='ip --color=auto'

# Confirm before overwriting
alias cp="cp -iv"
alias mv='mv -iv'
alias rm='rm -i'

# Human-readable sizes
alias df='df -h'
alias free='free -m'

# Misc
alias cls="clear"
alias rd="rmdir"
alias python='python3'
alias py="python3"
alias ipython="ipython --TerminalInteractiveShell.editing_mode=vi"
alias weather='curl wttr.in'
alias lsb="lsb_release -a"
alias h="history"
alias q="exit"
alias :q='exit'
alias m='make'
alias news='newsboat'

# -------------------------------- EDITORS ---------------------------------
alias v="nvim"
alias vim='nvim'
alias e="$EDITOR"
alias :e="$EDITOR ."
alias v.="$EDITOR ."
alias sv="sudo $EDITOR"

# Config files
alias za="$EDITOR ~/dots/zsh/.zsh_aliases"
alias zrc="nvim $HOME/dots/zsh/.zshrc"
alias zra="nvim $HOME/dots/zsh/.zsh_aliases"
alias zrf="nvim $HOME/dots/zsh/.zsh_functions"
alias vrc="nvim $HOME/.config/nvim/init.lua"
alias nrc="nvim $HOME/nix/flake.nix"
alias nvdir="cd $HOME/.config/nvim"

# -------------------------------- TMUX ---------------------------------
alias t="tmux -2"
alias tmux="tmux -2"

# -------------------------------- GIT ---------------------------------
alias g="git"
alias gca="git add .; git commit"
alias gco="git checkout"
alias gs="git status"
alias gp="git push -u origin HEAD"
alias gpull="git pull --rebase"

# -------------------------------- EMACS ---------------------------------
# Emacs daemon aliases - cross-platform
case "$(uname -s)" in
    Darwin)
        if [[ -f /opt/homebrew/opt/emacs-plus@31/bin/emacsclient ]]; then
            alias emacs="/opt/homebrew/opt/emacs-plus@31/bin/emacsclient -c -a ''"
            alias ec="/opt/homebrew/opt/emacs-plus@31/bin/emacsclient -c -a ''"
        else
            alias emacs="emacsclient -c -a ''"
            alias ec="emacsclient -c -a ''"
        fi
        ;;
    Linux)
        alias emacs="emacsclient -c -a ''"
        alias ec="emacsclient -c -a ''"
        ;;
esac
alias ekill="emacsclient -e '(kill-emacs)'"
alias erc="emacsclient -c -a 'emacs' &  $HOME/dots/emacs/.emacs.d/init.el"

# -------------------------------- TOOLS ---------------------------------
alias less='bat'
alias icat="kitty +kitten icat"
alias xclip='xclip -selection c'
alias mypw="pwgen -c -n -s -y 16 -1"
alias ndate="date \"+%d-%m-%y\""
alias rl="exec zsh -l"
alias td='todoist --color'

# -------------------------------- NIX ---------------------------------
alias ni='nix-env -iA'
alias ns='nix-env -qaP'

# -------------------------------- SYSTEM ---------------------------------
alias hibernate="systemctl suspend"

# Distro-specific aliases
if command -v apt &> /dev/null; then
    alias sau="sudo apt update"
fi
if command -v yay &> /dev/null; then
    alias pacman="yay"
fi

# WSL-specific
if [[ -n "$IS_WSL" || -n "$WSL_DISTRO_NAME" ]]; then
    alias explorer='/mnt/c/Windows/explorer.exe'
fi

# -------------------------------- HARDWARE (Linux) ---------------------------------
# keyd restart
alias ks='pkill -f keyd-application-mapper; sudo systemctl restart keyd && setxkbmap -option compose:menu && keyd-application-mapper -d'

# Touchpad control for XPS 17
alias killtouchpad="xinput disable 'DELL098F:00 04F3:311C Touchpad'"
alias revivetouchpad="xinput enable 'DELL098F:00 04F3:311C Touchpad'"

# Keyboard layer switching (QMK)
alias qw='echo "n" | nc -U /tmp/rawtalk.sock'  # Switch to QWERTY
alias wq='echo "i" | nc -U /tmp/rawtalk.sock'  # Switch to Colemak-DH

# picom toggle
alias psa="systemctl --user start picom"
alias pst="systemctl --user stop picom"

# -------------------------------- MISC TOOLS ---------------------------------
alias zet="cd $HOME/Dropbox/Zettelkasten/"
alias rars="java -jar ~/bin/rars_533d3c0.jar"

# zshmarks
alias gt="jump"
alias s="showmarks"

# opencode
alias oc="opencode"
alias ocf="/Users/morph/.opencode-fast"
alias ofast="/Users/morph/.opencode-fast"
